#include "BuildConfig.h"

const Config BuildConfig;

Config::Config()
{
    // Name and copyright
    LAUNCHER_NAME = "@ENGINE_Project_Name@";
    LAUNCHER_DISPLAYNAME = "@ENGINE_Project_DisplayName@";
    LAUNCHER_COPYRIGHT = "@ENGINE_Project_Copyright@";
    LAUNCHER_DOMAIN = "@ENGINE_Project_Domain@";
    LAUNCHER_CONFIGFILE = "@ENGINE_Project_ConfigFile@";
    LAUNCHER_GIT = "@ENGINE_Project_Git@";

    USER_AGENT = "@ENGINE_Project_UserAgent@";
    USER_AGENT_UNCACHED = USER_AGENT + " (Uncached)";

    // Version information
    VERSION_MAJOR = std::stoi(std::string("@ENGINE_Project_VERSION_MAJOR@").empty() ? "0" : "@ENGINE_Project_VERSION_MAJOR@");
    VERSION_MINOR = std::stoi(std::string("@ENGINE_Project_VERSION_MINOR@").empty() ? "0" : "@ENGINE_Project_VERSION_MINOR@");
    VERSION_HOTFIX = std::stoi(std::string("@ENGINE_Project_VERSION_HOTFIX@").empty() ? "0" : "@ENGINE_Project_VERSION_HOTFIX@");
    VERSION_BUILD = std::stoi(std::string("@ENGINE_Project_VERSION_BUILD@").empty() ? "0" : "@ENGINE_Project_VERSION_BUILD@");

    IS_DEBUG_BUILD = @IS_DEBUG_BUILD@;

    BUILD_PLATFORM = "@ENGINE_Project_BUILD_PLATFORM@";
    UPDATER_BASE = "@ENGINE_Project_UPDATER_BASE@";
    NOTIFICATION_URL = "@ENGINE_Project_NOTIFICATION_URL@";
    FULL_VERSION_STR = "@ENGINE_Project_VERSION_MAJOR@.@ENGINE_Project_VERSION_MINOR@.@ENGINE_Project_VERSION_BUILD@";

    GIT_COMMIT = "@ENGINE_Project_GIT_COMMIT@";
    GIT_REFSPEC = "@ENGINE_Project_GIT_REFSPEC@";
    if(GIT_REFSPEC.starts_with("refs/heads/") && !UPDATER_BASE.empty() && !BUILD_PLATFORM.empty() && VERSION_BUILD >= 0)
    {
        VERSION_CHANNEL = GIT_REFSPEC;
        VERSION_CHANNEL.erase(VERSION_CHANNEL.find("refs/heads/"), 12);
        UPDATER_ENABLED = true;
    }
    else
    {
        VERSION_CHANNEL = "custom";
    }

    VERSION_STR = "@ENGINE_Project_VERSION_STRING@";
    NEWS_URL = "@ENGINE_Project_NEWS_URL@";
    NEWS_RSS_URL = "@ENGINE_Project_NEWS_RSS_URL@";
    PASTE_EE_KEY = "@ENGINE_Project_PASTE_EE_API_KEY@";
    MSA_CLIENT_ID = "@ENGINE_Project_MSA_CLIENT_ID@";
    IMGUR_CLIENT_ID = "@ENGINE_Project_IMGUR_CLIENT_ID@";
    META_URL = "@ENGINE_Project_META_URL@";

    BUG_TRACKER_URL = "@ENGINE_Project_BUG_TRACKER_URL@";
    DISCORD_URL = "@ENGINE_Project_DISCORD_URL@";
    SUBREDDIT_URL = "@ENGINE_Project_SUBREDDIT_URL@";
    PATREON_URL = "@ENGINE_Project_PATREON_URL@";
}

std::string Config::printableVersionString() const
{
    std::string vstr = std::format("{}.{}.{}", std::to_string(VERSION_MAJOR), std::to_string(VERSION_MINOR), std::to_string(VERSION_HOTFIX));

    // If the build is not a main release, append the channel
    if(VERSION_CHANNEL != "develop")
    {
        vstr += "-" + VERSION_CHANNEL;
    }

    // if a build number is set, also add it to the end
    if(VERSION_BUILD >= 0)
    {
        vstr += "-" + std::to_string(VERSION_BUILD);
    }
    return vstr;
}
